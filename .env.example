# PostgreSQL connection string
DATABASE_URL=postgresql://trekky:trekky@localhost:5432/trekky

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# NextAuth — OAuth session bridge (generate with: openssl rand -base64 32)
AUTH_SECRET=YOUR_AUTH_SECRET_HERE

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
# Callback URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (github.com/settings/developers → OAuth Apps)
# Callback URI: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Facebook OAuth (developers.facebook.com → My Apps → Facebook Login)
# Callback URI: http://localhost:3000/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
